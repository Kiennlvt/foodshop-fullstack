{
  "project": {
    "name": "FoodShop Fullstack",
    "backend": "ASP.NET Core 8 Web API",
    "frontend": "React + Vite",
    "database": "SQL Server",
    "authentication": "JWT",
    "testing": "xUnit + Moq"
  },

  "rules": [
    "Use async/await for all database operations",
    "Use Repository Pattern",
    "Use DTOs for API requests/responses",
    "Do not place business logic inside controllers",
    "Keep controllers thin",
    "Use dependency injection properly",
    "Use EF Core Code First",
    "Write clean and readable code",
    "Fix build/runtime errors automatically when possible",
    "Run tests after making backend changes"
  ],

  "permissions": {
    "allow": [
      "Bash(dotnet package *)",
      "Bash(dotnet restore *)",
      "Bash(dotnet build *)",
      "Bash(dotnet clean *)",
      "Bash(dotnet run *)",
      "Bash(dotnet ef *)",
      "Bash(dotnet tool *)",
      "Bash(dotnet dev-certs *)",

      "Bash(npm install *)",
      "Bash(npm run *)",

      "Bash(curl *)",

      "Bash(taskkill *)",
      "Bash(powershell *)",

      "PowerShell(Get-ChildItem *)",
      "PowerShell(Get-Command *)",
      "PowerShell(Start-Process *)",

      "Read(//tmp/**)"
    ]
  }
}